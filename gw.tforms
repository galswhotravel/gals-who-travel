<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Gals Who Travel</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;500;600;700&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
:root {
  --red:    #E8180A;
  --navy:   #0B213E;
  --pink:   #FFE3E6;
  --sand:   #FAF6F1;
  --white:  #FFFFFF;
  --grey-2: #D9D9D9;
  --grey-3: #8C8C8C;
  --grey-1: #F4F4F4;
  --text:   #1A1A1A;
  --font-display: 'Playfair Display', Georgia, serif;
  --font-body:    'DM Sans', Arial, sans-serif;
  --radius-card: 16px;
  --radius-btn:  6px;
  --shadow-card: 0 4px 24px rgba(11,33,62,0.10);
  --shadow-hover: 0 8px 40px rgba(11,33,62,0.16);
  --transition: 0.25s cubic-bezier(0.4,0,0.2,1);
}
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
body { font-family: var(--font-body); color: var(--text); background: var(--sand); }

/* ── Section ── */
.gwt-split-section { background: var(--sand); padding: 80px 24px; }
.gwt-split-inner   { max-width: 1160px; margin: 0 auto; }

.gwt-split-eyebrow { text-align: center; margin-bottom: 48px; }
.gwt-split-eyebrow span {
  display: inline-block;
  font-size: 11px; font-weight: 600; letter-spacing: 0.14em;
  text-transform: uppercase; color: var(--red);
  padding-bottom: 10px; border-bottom: 2px solid var(--red);
}
.gwt-split-eyebrow h2 {
  font-family: var(--font-display);
  font-size: clamp(28px, 4vw, 42px);
  font-weight: 500; color: var(--navy);
  margin-top: 14px; line-height: 1.2;
}

/* ── Grid ── */
.gwt-split-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 28px;
  align-items: stretch;
}

/* ── Card ── */
.gwt-card {
  border-radius: var(--radius-card);
  overflow: hidden;
  display: flex;
  flex-direction: column;
  box-shadow: var(--shadow-card);
  transition: box-shadow var(--transition), transform var(--transition);
}
.gwt-card:hover {
  transform: translateY(-3px);
  box-shadow: var(--shadow-hover);
}

/* Image */
.gwt-card__img-wrap {
  width: 100%;
  aspect-ratio: 800 / 540;
  overflow: hidden;
  flex-shrink: 0;
}
.gwt-card__img-wrap img {
  width: 100%; height: 100%;
  object-fit: cover;
  display: block;
  transition: transform 0.5s ease;
}
.gwt-card:hover .gwt-card__img-wrap img { transform: scale(1.03); }

/* Content block */
.gwt-card__content {
  flex: 1;
  display: flex;
  flex-direction: column;
  padding: 36px 36px 36px;
}

.gwt-card--work .gwt-card__content { background: var(--pink); }
.gwt-card--trip .gwt-card__content { background: var(--white); border: 2px solid var(--pink); border-top: none; }

/* Label */
.gwt-card__label {
  display: inline-flex; align-items: center; gap: 7px;
  font-size: 10.5px; font-weight: 600; letter-spacing: 0.12em;
  text-transform: uppercase; margin-bottom: 16px;
  width: fit-content; padding: 5px 12px; border-radius: 999px;
}
.gwt-card--work .gwt-card__label { background: rgba(232,24,10,0.12); color: var(--red); }
.gwt-card--trip .gwt-card__label { background: var(--pink); color: var(--red); }
.gwt-card__label-dot { width: 6px; height: 6px; border-radius: 50%; flex-shrink: 0; }
.gwt-card--work .gwt-card__label-dot { background: var(--red); }
.gwt-card--trip .gwt-card__label-dot { background: var(--red); }

/* Headline */
.gwt-card__headline {
  font-family: var(--font-display);
  font-weight: 500; font-size: clamp(20px, 2.4vw, 27px);
  line-height: 1.2; margin-bottom: 14px;
}
.gwt-card--work .gwt-card__headline { color: var(--navy); }
.gwt-card--trip .gwt-card__headline { color: var(--navy); }

/* Copy */
.gwt-card__copy {
  font-size: 15px; line-height: 1.65; font-weight: 400;
  flex: 1; margin-bottom: 28px;
}
.gwt-card--work .gwt-card__copy { color: #4A5568; }
.gwt-card--trip .gwt-card__copy { color: #4A5568; }

/* ── Buttons ── */
.gwt-btn {
  display: inline-flex; align-items: center; justify-content: center; gap: 9px;
  font-family: var(--font-body); font-size: 14px; font-weight: 600;
  letter-spacing: 0.02em; padding: 14px 28px;
  border-radius: var(--radius-btn); border: none; cursor: pointer;
  text-decoration: none;
  transition: background var(--transition), transform var(--transition), box-shadow var(--transition);
  align-self: flex-start; white-space: nowrap;
}
.gwt-btn--primary { background: var(--red); color: var(--white); }
.gwt-btn--primary:hover {
  background: #c9130b;
  transform: translateY(-1px);
  box-shadow: 0 6px 20px rgba(232,24,10,0.30);
}
.gwt-btn__arrow { display: inline-block; transition: transform var(--transition); }
.gwt-btn:hover .gwt-btn__arrow { transform: translateX(4px); }

/* ── Modal ── */
.gwt-modal-overlay {
  position: fixed; inset: 0;
  background: rgba(11,33,62,0.65);
  backdrop-filter: blur(4px); -webkit-backdrop-filter: blur(4px);
  z-index: 9000; display: flex; align-items: center; justify-content: center;
  padding: 24px; opacity: 0; visibility: hidden;
  transition: opacity 0.28s ease, visibility 0.28s ease;
}
.gwt-modal-overlay.is-open { opacity: 1; visibility: visible; }
.gwt-modal {
  background: var(--white); border-radius: 20px;
  width: 100%; max-width: 560px; max-height: 90vh;
  overflow-y: auto; overscroll-behavior: contain;
  transform: translateY(24px) scale(0.98);
  transition: transform 0.30s cubic-bezier(0.34,1.56,0.64,1);
  box-shadow: 0 24px 80px rgba(11,33,62,0.25);
}
.gwt-modal-overlay.is-open .gwt-modal { transform: translateY(0) scale(1); }
.gwt-modal__header {
  padding: 32px 36px 0;
  display: flex; align-items: flex-start; justify-content: space-between; gap: 16px;
}
.gwt-modal__title-block { flex: 1; }
.gwt-modal__eyebrow {
  font-size: 10.5px; font-weight: 600; letter-spacing: 0.12em;
  text-transform: uppercase; color: var(--red); margin-bottom: 6px; display: block;
}
.gwt-modal__title {
  font-family: var(--font-display);
  font-size: 24px; font-weight: 500; color: var(--navy); line-height: 1.2;
}
.gwt-modal__close {
  width: 36px; height: 36px; border-radius: 50%;
  border: 1.5px solid var(--grey-2); background: transparent; cursor: pointer;
  display: flex; align-items: center; justify-content: center; flex-shrink: 0;
  color: var(--grey-3); transition: background var(--transition), color var(--transition);
  margin-top: -2px;
}
.gwt-modal__close:hover { background: var(--grey-1); color: var(--navy); }
.gwt-modal__close:focus-visible { outline: 2px solid var(--red); outline-offset: 2px; }
.gwt-modal__body { padding: 20px 36px 36px; }
.gwt-modal__subtitle {
  font-size: 14px; color: #5A6478; line-height: 1.6; margin-bottom: 28px; padding-top: 8px;
}

/* Form */
.gwt-form { display: flex; flex-direction: column; gap: 18px; }
.gwt-form__row { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
.gwt-form__field { display: flex; flex-direction: column; gap: 6px; }
.gwt-form__label { font-size: 12.5px; font-weight: 600; color: var(--navy); letter-spacing: 0.01em; }
.gwt-form__required { color: var(--red); margin-left: 2px; }
.gwt-form__input,
.gwt-form__textarea {
  font-family: var(--font-body); font-size: 14px; color: var(--text);
  background: var(--sand); border: 1.5px solid var(--grey-2);
  border-radius: 8px; padding: 11px 14px;
  transition: border-color var(--transition), box-shadow var(--transition);
  outline: none; width: 100%; -webkit-appearance: none;
}
.gwt-form__input:focus, .gwt-form__textarea:focus {
  border-color: var(--navy); box-shadow: 0 0 0 3px rgba(11,33,62,0.08); background: var(--white);
}
.gwt-form__input.is-error, .gwt-form__textarea.is-error {
  border-color: var(--red); box-shadow: 0 0 0 3px rgba(232,24,10,0.08);
}
.gwt-form__error { font-size: 12px; color: var(--red); font-weight: 500; display: none; }
.gwt-form__error.is-visible { display: block; }
.gwt-form__textarea { min-height: 110px; resize: vertical; line-height: 1.5; }
.gwt-form__submit {
  width: 100%; justify-content: center; padding: 15px 28px;
  font-size: 15px; margin-top: 4px; border-radius: 8px;
}
.gwt-form__success {
  display: none; flex-direction: column; align-items: center;
  text-align: center; padding: 20px 0 8px; gap: 14px;
}
.gwt-form__success.is-visible { display: flex; }
.gwt-form__success-icon {
  width: 56px; height: 56px; border-radius: 50%;
  background: #E8F5E9; display: flex; align-items: center;
  justify-content: center; color: #2E7D32; font-size: 22px;
}
.gwt-form__success-title {
  font-family: var(--font-display); font-size: 20px; font-weight: 500; color: var(--navy);
}
.gwt-form__success-msg { font-size: 14px; color: #5A6478; line-height: 1.6; max-width: 340px; }

/* ── Responsive ── */
@media (max-width: 860px) {
  .gwt-split-grid { grid-template-columns: 1fr; gap: 20px; }
  .gwt-split-section { padding: 64px 20px; }
  .gwt-form__row { grid-template-columns: 1fr; }
}
@media (max-width: 560px) {
  .gwt-card__content { padding: 24px 22px 28px; }
  .gwt-modal__header { padding: 24px 22px 0; }
  .gwt-modal__body   { padding: 16px 22px 28px; }
  .gwt-modal__title  { font-size: 20px; }
}
.gwt-btn:focus-visible, .gwt-form__input:focus-visible, .gwt-form__textarea:focus-visible {
  outline: 2px solid var(--red); outline-offset: 2px;
}
@media (prefers-reduced-motion: reduce) {
  *, *::before, *::after { transition-duration: 0.01ms !important; animation-duration: 0.01ms !important; }
}
body.gwt-scroll-lock { overflow: hidden; }

</style>
</head>
<body>

<section class="gwt-split-section" aria-labelledby="split-heading">
  <div class="gwt-split-inner">

    <div class="gwt-split-eyebrow">
      <span>how can we help?</span>
      <h2 id="split-heading">you're in the right place!!!</h2>
    </div>

    <div class="gwt-split-grid">

      <!-- Card 1: Work With Us -->
      <article class="gwt-card gwt-card--work" aria-label="Work with Gals Who Travel">
        <div class="gwt-card__img-wrap">
          <img src="data:image/jpeg;base64," alt="Gals Who Travel group in the desert at golden hour" loading="lazy">
        </div>
        <div class="gwt-card__content">
          <div class="gwt-card__label">
            <span class="gwt-card__label-dot" aria-hidden="true"></span>
            for brands and partners
          </div>
          <h3 class="gwt-card__headline">would you like to work with us?</h3>
          <p class="gwt-card__copy">
            gals who travel partners with brands, destinations, hotels, tourism boards, and travel-related businesses to create meaningful collaborations with our highly engaged community.
          </p>
          <button
            class="gwt-btn gwt-btn--primary"
            id="open-collab-modal"
            aria-haspopup="dialog"
            aria-controls="collab-modal"
            type="button">
            submit collaboration idea
            <span class="gwt-btn__arrow" aria-hidden="true">→</span>
          </button>
        </div>
      </article>

      <!-- Card 2: Find a Trip -->
      <article class="gwt-card gwt-card--trip" aria-label="Find a Gals Who Travel trip">
        <div class="gwt-card__img-wrap">
          <img src="data:image/jpeg;base64," alt="Gals Who Travel group exploring Gili T" loading="lazy">
        </div>
        <div class="gwt-card__content">
          <div class="gwt-card__label">
            <span class="gwt-card__label-dot" aria-hidden="true"></span>
            for solo female travellers
          </div>
          <h3 class="gwt-card__headline">looking for a gals trip?</h3>
          <p class="gwt-card__copy">
            join hundreds of women travelling the world with gals who travel. women-only group adventures designed for solo travellers ready to explore, connect, and make memories.
          </p>
          <a
            href="https://galswhotravel.com"
            class="gwt-btn gwt-btn--primary"
            aria-label="Browse Gals Who Travel trips">
            browse trips
            <span class="gwt-btn__arrow" aria-hidden="true">→</span>
          </a>
        </div>
      </article>

    </div>
  </div>
</section>

<!-- Modal -->
<div
  class="gwt-modal-overlay"
  id="collab-modal"
  role="dialog"
  aria-modal="true"
  aria-labelledby="modal-title"
  aria-describedby="modal-subtitle"
  tabindex="-1">
  <div class="gwt-modal">
    <div class="gwt-modal__header">
      <div class="gwt-modal__title-block">
        <span class="gwt-modal__eyebrow">partnerships and collaborations</span>
        <h2 class="gwt-modal__title" id="modal-title">let's work together</h2>
      </div>
      <button class="gwt-modal__close" id="close-collab-modal" aria-label="Close" type="button">
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
          <path d="M1 1L13 13M13 1L1 13" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
        </svg>
      </button>
    </div>
    <div class="gwt-modal__body">
      <p class="gwt-modal__subtitle" id="modal-subtitle">
        tell us about your brand and how you'd like to collaborate.
      </p>
      <form class="gwt-form" id="collab-form" novalidate aria-label="Collaboration enquiry form">
        <div class="gwt-form__row">
          <div class="gwt-form__field">
            <label class="gwt-form__label" for="field-name">full name<span class="gwt-form__required" aria-hidden="true">*</span></label>
            <input class="gwt-form__input" type="text" id="field-name" name="fullName" placeholder="Jane Smith" autocomplete="name" required aria-required="true" aria-describedby="error-name">
            <span class="gwt-form__error" id="error-name" role="alert">please enter your full name</span>
          </div>
          <div class="gwt-form__field">
            <label class="gwt-form__label" for="field-company">company / brand<span class="gwt-form__required" aria-hidden="true">*</span></label>
            <input class="gwt-form__input" type="text" id="field-company" name="company" placeholder="Brand Co." autocomplete="organization" required aria-required="true" aria-describedby="error-company">
            <span class="gwt-form__error" id="error-company" role="alert">please enter your company or brand name</span>
          </div>
        </div>
        <div class="gwt-form__field">
          <label class="gwt-form__label" for="field-email">email address<span class="gwt-form__required" aria-hidden="true">*</span></label>
          <input class="gwt-form__input" type="email" id="field-email" name="email" placeholder="jane@brandco.com" autocomplete="email" required aria-required="true" aria-describedby="error-email">
          <span class="gwt-form__error" id="error-email" role="alert">please enter a valid email address</span>
        </div>
        <div class="gwt-form__field">
          <label class="gwt-form__label" for="field-idea">collaboration idea<span class="gwt-form__required" aria-hidden="true">*</span></label>
          <textarea class="gwt-form__textarea" id="field-idea" name="idea" placeholder="tell us how you'd like to work together..." required aria-required="true" aria-describedby="error-idea"></textarea>
          <span class="gwt-form__error" id="error-idea" role="alert">please share your collaboration idea</span>
        </div>
        <button class="gwt-btn gwt-btn--primary gwt-form__submit" type="submit">
          send enquiry
          <span class="gwt-btn__arrow" aria-hidden="true">→</span>
        </button>
      </form>
      <div class="gwt-form__success" id="form-success" role="status" aria-live="polite" aria-atomic="true">
        <div class="gwt-form__success-icon" aria-hidden="true">✓</div>
        <p class="gwt-form__success-title">message sent!</p>
        <p class="gwt-form__success-msg">thank you for your enquiry. our team will be in touch shortly.</p>
      </div>
    </div>
  </div>
</div>

<script>
(function () {
  'use strict';
  const overlay=document.getElementById('collab-modal'),openBtn=document.getElementById('open-collab-modal'),closeBtn=document.getElementById('close-collab-modal'),form=document.getElementById('collab-form'),successPanel=document.getElementById('form-success');
  function getFocusable(c){return Array.from(c.querySelectorAll('button,[href],input,textarea,select,[tabindex]:not([tabindex="-1"])')).filter(e=>!e.disabled&&e.offsetParent!==null);}
  function trapFocus(e){const f=getFocusable(overlay.querySelector('.gwt-modal')),first=f[0],last=f[f.length-1];if(e.key==='Tab'){if(e.shiftKey){if(document.activeElement===first){e.preventDefault();last.focus();}}else{if(document.activeElement===last){e.preventDefault();first.focus();}}}if(e.key==='Escape')closeModal();}
  function openModal(){overlay.classList.add('is-open');document.body.classList.add('gwt-scroll-lock');overlay.setAttribute('aria-hidden','false');setTimeout(()=>{const f=getFocusable(overlay.querySelector('.gwt-modal'));if(f[0])f[0].focus();},50);overlay.addEventListener('keydown',trapFocus);}
  function closeModal(){overlay.classList.remove('is-open');document.body.classList.remove('gwt-scroll-lock');overlay.setAttribute('aria-hidden','true');overlay.removeEventListener('keydown',trapFocus);openBtn.focus();}
  openBtn.addEventListener('click',openModal);
  closeBtn.addEventListener('click',closeModal);
  overlay.addEventListener('click',function(e){if(e.target===overlay)closeModal();});
  function validateField(input){const errorEl=document.getElementById(input.id.replace('field-','error-'));let valid=input.type==='email'?/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(input.value.trim()):input.value.trim().length>0;input.classList.toggle('is-error',!valid);if(errorEl)errorEl.classList.toggle('is-visible',!valid);return valid;}
  ['field-name','field-company','field-email','field-idea'].forEach(id=>{const el=document.getElementById(id);if(el){el.addEventListener('blur',()=>validateField(el));el.addEventListener('input',()=>{if(el.classList.contains('is-error'))validateField(el);});}});
  form.addEventListener('submit',function(e){e.preventDefault();const fields=['field-name','field-company','field-email','field-idea'].map(id=>document.getElementById(id));const allValid=fields.every(f=>validateField(f));if(!allValid){const first=fields.find(f=>f.classList.contains('is-error'));if(first)first.focus();return;}form.style.display='none';successPanel.classList.add('is-visible');setTimeout(()=>{form.reset();fields.forEach(f=>f.classList.remove('is-error'));},500);});
  overlay.addEventListener('transitionend',function(){if(!overlay.classList.contains('is-open')){setTimeout(()=>{form.style.display='';successPanel.classList.remove('is-visible');},100);}});
  overlay.setAttribute('aria-hidden','true');
})();
</script>
</body>
</html>
